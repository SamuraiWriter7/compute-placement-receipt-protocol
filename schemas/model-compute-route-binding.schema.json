{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/model-compute-route-binding.schema.json",

  "title": "Model-to-Compute Route Binding",

  "description": "A machine-readable record that binds an AI task to a selected model, compute requirements, compute type, and downstream placement evaluation records.",

  "type": "object",

  "additionalProperties": false,

  "required": [
    "schema_version",
    "protocol",
    "route_binding_id",
    "task_ref",
    "model_selection",
    "compute_requirement",
    "compute_route",
    "binding_reason",
    "bound_at",
    "binding_actor",
    "evidence_refs"
  ],

  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.3"
    },

    "protocol": {
      "type": "string",
      "const": "compute-placement-receipt-protocol"
    },

    "route_binding_id": {
      "type": "string",
      "minLength": 1
    },

    "task_ref": {
      "type": "object",

      "additionalProperties": false,

      "required": [
        "task_id",
        "task_type"
      ],

      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1
        },

        "workload_id": {
          "type": "string",
          "minLength": 1
        },

        "task_type": {
          "type": "string",

          "enum": [
            "classification",
            "generation",
            "reasoning",
            "retrieval",
            "research",
            "vision",
            "audio",
            "multimodal",
            "tool_use",
            "agent_action",
            "training",
            "fine_tuning",
            "embedding",
            "other"
          ]
        },

        "priority": {
          "type": "string",

          "enum": [
            "low",
            "normal",
            "high",
            "critical"
          ]
        },

        "latency_class": {
          "type": "string",

          "enum": [
            "real_time",
            "interactive",
            "nearline",
            "batch",
            "flexible"
          ]
        }
      }
    },

    "model_selection": {
      "type": "object",

      "additionalProperties": false,

      "required": [
        "model_id",
        "model_class",
        "selection_reason_codes"
      ],

      "properties": {
        "model_id": {
          "type": "string",
          "minLength": 1
        },

        "model_class": {
          "type": "string",

          "enum": [
            "tiny_model",
            "small_language_model",
            "medium_model",
            "large_model",
            "frontier_model",
            "specialized_model",
            "multimodal_model",
            "embedding_model",
            "other"
          ]
        },

        "provider": {
          "type": "string",
          "minLength": 1
        },

        "version": {
          "type": "string",
          "minLength": 1
        },

        "selection_reason_codes": {
          "type": "array",

          "minItems": 1,

          "uniqueItems": true,

          "items": {
            "type": "string",
            "minLength": 1
          }
        },

        "selection_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },

    "compute_requirement": {
      "type": "object",

      "additionalProperties": false,

      "required": [
        "accelerator_required",
        "memory_requirement",
        "execution_mode"
      ],

      "properties": {
        "accelerator_required": {
          "type": "boolean"
        },

        "accelerator_classes": {
          "type": "array",

          "uniqueItems": true,

          "items": {
            "type": "string",

            "enum": [
              "cpu",
              "gpu",
              "npu",
              "tpu",
              "fpga",
              "custom_accelerator",
              "none",
              "other"
            ]
          }
        },

        "memory_requirement": {
          "type": "object",

          "additionalProperties": false,

          "required": [
            "minimum_gb"
          ],

          "properties": {
            "minimum_gb": {
              "type": "number",
              "minimum": 0
            },

            "preferred_gb": {
              "type": "number",
              "minimum": 0
            },

            "memory_type": {
              "type": "string",

              "enum": [
                "system_memory",
                "device_memory",
                "unified_memory",
                "distributed_memory",
                "unspecified"
              ]
            }
          }
        },

        "execution_mode": {
          "type": "string",

          "enum": [
            "single_node",
            "multi_node",
            "distributed",
            "edge_local",
            "hybrid",
            "other"
          ]
        },

        "minimum_node_count": {
          "type": "integer",
          "minimum": 1
        },

        "preferred_node_count": {
          "type": "integer",
          "minimum": 1
        },

        "latency_ms_max": {
          "type": "number",
          "minimum": 0
        },

        "data_residency": {
          "type": "array",

          "uniqueItems": true,

          "items": {
            "type": "string",
            "minLength": 1
          }
        },

        "security_class": {
          "type": "string",
          "minLength": 1
        },

        "energy_policy_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },

    "compute_route": {
      "type": "object",

      "additionalProperties": false,

      "required": [
        "selected_compute_type",
        "execution_scope"
      ],

      "properties": {
        "selected_compute_type": {
          "type": "string",

          "enum": [
            "cpu",
            "gpu",
            "npu",
            "tpu",
            "fpga",
            "custom_accelerator",
            "mixed_compute",
            "other"
          ]
        },

        "execution_scope": {
          "type": "string",

          "enum": [
            "device",
            "local_edge",
            "edge_cluster",
            "regional",
            "cloud",
            "distributed_fabric",
            "hybrid"
          ]
        },

        "candidate_evaluation_ref": {
          "type": "string",
          "minLength": 1
        },

        "placement_receipt_ref": {
          "type": "string",
          "minLength": 1
        },

        "route_policy_refs": {
          "type": "array",

          "uniqueItems": true,

          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },

    "binding_reason": {
      "type": "object",

      "additionalProperties": false,

      "required": [
        "primary_reason",
        "reason_codes",
        "summary"
      ],

      "properties": {
        "primary_reason": {
          "type": "string",

          "enum": [
            "task_complexity",
            "model_compatibility",
            "latency_requirement",
            "memory_requirement",
            "accelerator_requirement",
            "data_locality",
            "cost_policy",
            "energy_policy",
            "security_policy",
            "availability",
            "manual_override",
            "other"
          ]
        },

        "reason_codes": {
          "type": "array",

          "minItems": 1,

          "uniqueItems": true,

          "items": {
            "type": "string",
            "minLength": 1
          }
        },

        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },

    "bound_at": {
      "type": "string",
      "format": "date-time"
    },

    "binding_actor": {
      "type": "object",

      "additionalProperties": false,

      "required": [
        "actor_type",
        "actor_id"
      ],

      "properties": {
        "actor_type": {
          "type": "string",

          "enum": [
            "router",
            "scheduler",
            "agent",
            "human",
            "policy_engine",
            "orchestrator",
            "hybrid"
          ]
        },

        "actor_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },

    "evidence_refs": {
      "type": "array",

      "items": {
        "type": "object",

        "additionalProperties": false,

        "required": [
          "evidence_type",
          "ref"
        ],

        "properties": {
          "evidence_type": {
            "type": "string",

            "enum": [
              "task_profile",
              "model_profile",
              "benchmark_record",
              "compatibility_record",
              "policy_snapshot",
              "telemetry_snapshot",
              "capacity_snapshot",
              "energy_snapshot",
              "network_snapshot",
              "manual_record",
              "other"
            ]
          },

          "ref": {
            "type": "string",
            "minLength": 1
          },

          "digest": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
